# ── Required API Keys ──────────────────────────────────
NUMVERIFY_API_KEY=
TRUECALLER_API_KEY=
HUNTER_API_KEY=

# ── Optional: SpiderFoot (self-hosted) ────────────────
SPIDERFOOT_API_URL=http://127.0.0.1:5001
SPIDERFOOT_API_KEY=

# ── Neo4j ─────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=osint_secure_password

# ── Tor Proxy ─────────────────────────────────────────
TOR_PROXY_HOST=tor
TOR_PROXY_PORT=9050

# ── HTTP Client ───────────────────────────────────────
RATE_LIMIT_DELAY=2
MAX_RETRIES=3
TIMEOUT=10

# ── Periodic Scanner ─────────────────────────────────
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=6

# ── GNN Risk Scoring ─────────────────────────────────
GNN_ENABLED=true
GNN_HIDDEN_DIM=64
GNN_LEARNING_RATE=0.01
GNN_EPOCHS=100
